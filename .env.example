# 部署环境变量模板
# 用法：cp .env.example .env，改掉下面 change_me 占位密码 + 各 *_DOMAIN 域名即可部署
# 两种部署方式（详见 docs/03-部署/宝塔面板+Docker部署方案.md）：
#   方式一 CI 构建：docker compose pull && docker compose up -d（镜像由 GitHub Actions 推到 GHCR）
#   方式二 本地构建：docker compose up -d --build（用本地源码构建，不碰 GHCR，需完整源码）

# ===== 数据库（请改为强密码，建议纯字母数字，避免特殊符号转义问题）=====
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=agentpm
MYSQL_USER=agentpm
MYSQL_PASSWORD=change_me_db

# ===== Redis（请改为强密码，不能留空）=====
REDIS_PASSWORD=change_me_redis

# ===== JWT（上线前必须替换为强随机值，可用 openssl rand -hex 32 生成）=====
JWT_SECRET=change_me_to_a_strong_random_secret

# ===== 前端网关（单容器托管所有前端，仅绑本机回环 127.0.0.1，供宝塔反代）=====
# 所有前端共用一个网关容器，只占一个本机端口。宝塔为每个子域名配反向代理，都指向此端口，
# 网关按域名（server_name）分流到对应前端：
#   admin.xxx → 127.0.0.1:8080（管理后台）
#   m.xxx     → 127.0.0.1:8080（移动端 H5）
# 不填则用默认 8080。端口被占用时才改。勿用 80（会与宝塔 Nginx 冲突）。
# GATEWAY_HTTP_PORT=8080

# 各前端对外域名（网关据此生成 nginx server_name，宝塔反代域名需与此一致）。
# 新增前端：docker/frontends.json 加一行 + 这里加一个 <NAME 大写>_DOMAIN。
ADMIN_DOMAIN=admin.example.com
MOBILE_DOMAIN=m.example.com

# ===== 镜像仓库 =====
# IMAGE_OWNER：你的 GitHub 用户名/组织名（小写），即镜像所在的 GHCR 命名空间。
#   ★ fork 本项目部署的人，必须改成自己的 GitHub 用户名 ★
#   镜像由 GitHub Actions 自动推送到 ghcr.io/<IMAGE_OWNER>/agentpm-{server,gateway}
IMAGE_OWNER=fangjinbao
# IMAGE_TAG：镜像版本。默认 latest（最新）。回滚时改成 CI 打的不可变标签，如 sha-1a2b3c4
IMAGE_TAG=latest


