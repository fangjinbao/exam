# 部署环境变量模板
# 用法：cp .env.example .env，改掉下面 5 个 change_me 占位值即可部署
#       cd server/docker && docker compose pull && docker compose up -d
# 镜像由 GitHub Actions 自动构建推送到 GHCR，服务器只拉取不构建（方案 C）

# ===== 数据库（请改为强密码，建议纯字母数字，避免特殊符号转义问题）=====
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=agentpm
MYSQL_USER=agentpm
MYSQL_PASSWORD=change_me_db

# ===== Redis（请改为强密码，不能留空）=====
REDIS_PASSWORD=change_me_redis

# ===== JWT（上线前必须替换为强随机值，可用 openssl rand -hex 32 生成）=====
JWT_SECRET=change_me_to_a_strong_random_secret

# ===== 前端容器对外端口（仅绑本机回环 127.0.0.1，供宝塔反代）=====
# 两个前端各占一个本机端口，宝塔为各自域名配反向代理：
#   admin.xxx → 127.0.0.1:8080（管理后台）
#   m.xxx     → 127.0.0.1:8081（移动端 H5）
# 不填则用下面默认值。端口被占用时才改。勿用 80（会与宝塔 Nginx 冲突）。
# ADMIN_HTTP_PORT=8080
# MOBILE_HTTP_PORT=8081

# ===== 镜像仓库 =====
# IMAGE_OWNER：你的 GitHub 用户名/组织名（小写），即镜像所在的 GHCR 命名空间。
#   ★ fork 本项目部署的人，必须改成自己的 GitHub 用户名 ★
#   镜像由各自仓库的 GitHub Actions 自动推送到 ghcr.io/<IMAGE_OWNER>/inspection-{server,admin,mobile}
IMAGE_OWNER=fangjinbao
# IMAGE_TAG：镜像版本。默认 latest（最新）。回滚时改成 CI 打的不可变标签，如 sha-1a2b3c4
IMAGE_TAG=latest


