# 依赖
node_modules/
.pnpm-store/

# 构建产物
dist/
dist-ssr/
*.local

# 环境变量：仅放行 CI 生产构建需要的 .env 和 .env.production（VITE_ 变量本就打包进客户端，非服务端密钥）
# .env.development 含高德安全密钥等本地开发配置，不纳入版本库（生产构建 vite build 不加载它）
!.env
!.env.production
.env.development
.env.local
.env.*.local

# 自动生成的类型声明（unplugin）
auto-imports.d.ts
components.d.ts

# 缓存
.vite/
.cache/
.eslintcache

# 日志
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# 测试覆盖率
coverage/
*.lcov

# 系统文件
.DS_Store
Thumbs.db

# 编辑器
.idea/
*.sw?
